import android.content.Intent
import android.os.Bundle
import android.os.Handler
import android.os.Looper
import androidx.appcompat.app.AppCompatActivity

class LoadingActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_loading)

        // Set a timer to move to the next screen after 2 seconds (2000 milliseconds)
        Handler(Looper.getMainLooper()).postDelayed({
            // Create an Intent to start the Initialize Account Activity
            val intent = Intent(this, InitializeAccountActivity::class.java)
            startActivity(intent)

            // Call finish() so the user can't press the 'back' button to return to the loading screen
            finish()
        }, 2000)
    }
}